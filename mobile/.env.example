# Firebase Configuration (required)
# Get these values from your Firebase Console > Project Settings > General > Your apps > Web app
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Backend API URL (optional, defaults to http://localhost:5000/api/v1)
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

# Firebase Auth Emulator (optional, uncomment to use local emulator)
# EXPO_PUBLIC_USE_FIREBASE_EMULATOR=true
