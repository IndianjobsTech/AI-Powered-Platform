# ===== PRODUCTION ENVIRONMENT VARIABLES =====
# Copy this to Railway's dashboard as env variables

# ===== SERVER =====
PORT=5000
NODE_ENV=production

# ===== FRONTEND URL (Vercel deployment) =====
# Update this to your actual Vercel deployment URL
FRONTEND_URL=https://freebuff-web.vercel.app

# ===== DATABASE (Railway PostgreSQL) =====
# Railway auto-injects this when you add a PostgreSQL plugin
# DATABASE_URL=postgresql://user:password@host:5432/railway

# ===== FIREBASE ADMIN =====
# From Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ===== WHATSAPP CLOUD API =====
WHATSAPP_API_TOKEN=EAAx...your-permanent-access-token...
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=freebuff-webhook-2025
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# ===== OPENAI =====
OPENAI_API_KEY=sk-your-openai-api-key

# ===== RAZORPAY =====
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ===== JWT =====
JWT_SECRET=your-production-jwt-secret-change-this
JWT_EXPIRES_IN=7d

# ===== SMTP (Nodemailer) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
